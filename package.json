{
	"name": "v-verse",
	"version": "0.1.4",
	"private": true,
	"scripts": {
		"dev": "next dev -p 3000",
		"build": "next build",
		"start": "next start",
		"type:check": "tsc --project tsconfig.json",
		"lint:check": "git diff --diff-filter=d --name-only HEAD | grep -E '\\.(js|jsx|ts|tsx)$' | xargs -r eslint --quiet",
		"lint:check:all": "eslint . --quiet",
		"lint:fix": "git diff --diff-filter=d --name-only HEAD | grep -E '\\.(js|jsx|ts|tsx)$' | xargs -r eslint --fix --quiet",
		"lint:fix:all": "eslint . --fix --quiet",
		"format:check": "prettier . --check",
		"format:fix": "prettier . --write",
		"lint:fix:windows": "node -e \"const { execSync } = require('child_process'); try { const changedFiles = execSync('git diff --diff-filter=d --name-only HEAD').toString().split(/\\r?\\n/).filter(file => /\\.(js|jsx|ts|tsx)$/.test(file)); if (changedFiles.length) { console.log('Linting ' + changedFiles.length + ' changed files...'); execSync('npx eslint --fix --quiet ' + changedFiles.join(' '), {stdio: 'inherit'}); } else { console.log('No JS/TS files changed.'); } } catch (e) { console.error(e); process.exit(1); }\""
	},
	"dependencies": {
		"@internationalized/date": "^3.5.5",
		"@nextui-org/react": "^2.4.6",
		"@nextui-org/system": "^2.2.5",
		"@nextui-org/theme": "^2.2.9",
		"@radix-ui/colors": "^3.0.0",
		"@radix-ui/react-popover": "^1.1.1",
		"@radix-ui/react-slider": "^1.2.0",
		"@radix-ui/react-slot": "^1.1.0",
		"@radix-ui/react-switch": "^1.1.1",
		"@radix-ui/react-toast": "^1.2.1",
		"@radix-ui/react-tooltip": "^1.1.2",
		"@reduxjs/toolkit": "^2.2.6",
		"@types/react-redux": "^7.1.33",
		"@types/react-slick": "^0.23.13",
		"axios": "^1.7.2",
		"formik": "^2.4.6",
		"async-mutex": "^0.5.0",
		"class-variance-authority": "^0.7.0",
		"clsx": "^2.1.1",
		"cookies-next": "^4.2.1",
		"emoji-mart": "^5.6.0",
		"firebase": "^11.0.2",
		"lucide-react": "^0.399.0",
		"next": "^14.2.21",
		"next-intl": "^3.26.3",
		"react": "^18",
		"react-dom": "^18",
		"react-redux": "^9.1.2",
		"redux-persist": "^6.0.0",
		"rtl-detect": "^1.1.2",
		"tailwind-merge": "^2.3.0",
		"tailwindcss-animate": "^1.0.7",
		"yup": "^1.4.0",
		"zustand": "^5.0.1"
	},
	"devDependencies": {
		"@types/node": "20.14.10",
		"@types/react": "18.3.3",
		"@types/react-dom": "^18",
		"@types/react-html-parser": "^2.0.6",
		"@typescript-eslint/eslint-plugin": "^8.12.2",
		"@typescript-eslint/parser": "^8.12.2",
		"autoprefixer": "^10.4.19",
		"eslint": "^8",
		"eslint-config-next": "^14.2.21",
		"eslint-config-prettier": "^9.1.0",
		"eslint-import-resolver-typescript": "^3.7.0",
		"eslint-plugin-import": "^2.31.0",
		"eslint-plugin-prettier": "^5.2.1",
		"eslint-plugin-unused-imports": "^4.1.4",
		"postcss": "^8.4.38",
		"prettier": "^3.3.2",
		"prettier-plugin-organize-imports": "^3.2.4",
		"prettier-plugin-tailwindcss": "^0.6.10",
		"tailwindcss": "^3.4.4",
		"typescript": "5.5.3"
	},
	"overrides": {
		"tough-cookie@<4.1.3": "4.1.3",
		"mime@<1.4.1": "1.4.1"
	}
}
